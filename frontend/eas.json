{
	"cli": {
		"version": ">= 15.0.0",
		"appVersionSource": "remote"
	},
	"build": {
		"base": {
			"env": {}
		},
		"development": {
			"extends": "base",
			"developmentClient": true,
			"distribution": "internal",
			"android": {
				"buildType": "apk",
				"gradleCommand": ":app:assembleDebug"
			}
		},
		"preview": {
			"extends": "base",
			"distribution": "internal",
			"android": {
				"buildType": "apk"
			}
		},
		"production": {
			"extends": "base",
			"autoIncrement": true,
			"android": {
				"buildType": "apk"
			}
		}
	}
}
